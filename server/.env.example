PORT=4000
NODE_ENV=development

# Comma-separated frontend origins. Example: http://localhost:5173,https://medacasa.ro
ALLOWED_ORIGINS=http://localhost:5173

# Use "log" locally and "ses" in production.
EMAIL_DELIVERY_MODE=log
AWS_REGION=eu-central-1
SES_FROM_EMAIL=programari@medacasa.ro
INTERNAL_APPOINTMENTS_EMAIL=programari@medacasa.ro
